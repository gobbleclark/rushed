# Shopify App Configuration
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SCOPES=read_products,read_orders,write_orders,write_own_subscription,read_own_subscription
HOST=https://your-app-domain.com

# Shop Configuration (for development)
SHOP=your-shop-domain.myshopify.com

# Webhook Secret (for HMAC verification)
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret_here

# Database Configuration
DATABASE_URL=file:./dev.db

# Environment
NODE_ENV=development

# Cron Job Configuration
ENABLE_CRON=false

# ShipHero Integration (Optional - removed as per requirements)
# SHIPHERO_TOKEN=your_shiphero_token_here
# SHIPHERO_ACCOUNT=your_account_id

# App Configuration
APP_NAME=Priority Handling
APP_VERSION=1.0.0

# Timezone for billing (default: America/New_York)
TZ=America/New_York

# Development/Testing Flags
DEBUG=false
SKIP_HMAC_VERIFICATION=false

# Extension Configuration
EXTENSION_HANDLE=post-purchase-priority-handling

# Default Settings (can be overridden per shop)
DEFAULT_PRIORITY_FEE_CENTS=500
DEFAULT_SLA_HOURS=2
DEFAULT_BILLING_CAP_CENTS=50000

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Performance Monitoring (Optional)
# SENTRY_DSN=your_sentry_dsn_here
# NEW_RELIC_LICENSE_KEY=your_new_relic_key_here

# Security
SESSION_SECRET=your_session_secret_here
ENCRYPTION_KEY=your_encryption_key_here
